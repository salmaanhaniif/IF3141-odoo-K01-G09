<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_fnb_table_kanban" model="ir.ui.view">
        <field name="name">fnb.table.kanban</field>
        <field name="model">fnb.table</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="capacity"/>
                <field name="location"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title" style="font-size: 18px;">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <i class="fa fa-users" title="Kapasitas"/> <field name="capacity"/> Orang
                                </div>
                                <div class="mt-2">
                                    <span t-if="record.location.raw_value == 'indoor'" class="badge rounded-pill text-bg-primary">Indoor</span>
                                    <span t-if="record.location.raw_value == 'outdoor'" class="badge rounded-pill text-bg-warning">Outdoor</span>
                                    <span t-if="record.location.raw_value == 'vip'" class="badge rounded-pill text-bg-danger">VIP Room</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_fnb_table_form" model="ir.ui.view">
        <field name="name">fnb.table.form</field>
        <field name="model">fnb.table</field>
        <field name="arch" type="xml">
            <form string="Data Meja">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nomor/Nama Meja"/>
                        <h1><field name="name" placeholder="Misal: Meja 01 atau VIP-A"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="location" widget="radio" options="{'horizontal': true}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>