<?xml version="1.0" encoding="UTF-8"?>
<odoo>
<record id="view_fnb_order_form" model="ir.ui.view">
    <field name="name">fnb.order.form</field>
    <field name="model">fnb.order</field>
    <field name="arch" type="xml">
        <form string="Nota Pesanan">
            <header>
                <button name="action_send_to_kitchen" string="Kirim ke Dapur" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                <button name="action_done" string="Selesaikan Pesanan" type="object" class="oe_highlight" invisible="status != 'kitchen'"/>
                <field name="status" widget="statusbar" statusbar_visible="draft,kitchen,done"/>
            </header>
            
            <sheet>
                <div class="oe_title">
                    <h1>
                        <field name="name" readonly="1"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="customer_name" placeholder="Nama Pelanggan..."/>
                        <field name="order_date"/>
                    </group>
                </group>

                <notebook>
                    <page string="Daftar Menu" name="order_lines">
                        <field name="order_line_ids">
                            <tree editable="bottom">
                                <field name="menu_id"/>
                                <field name="price_unit" widget="monetary"/>
                                <field name="quantity"/>
                                <field name="subtotal" widget="monetary" sum="Grand Total"/>
                            </tree>
                        </field>
                        
                        <group class="oe_subtotal_footer oe_right">
                            <field name="total_amount" class="oe_subtotal_footer_separator" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>
</odoo>