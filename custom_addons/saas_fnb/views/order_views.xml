<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_fnb_order_tree" model="ir.ui.view">
        <field name="name">fnb.order.tree</field>
        <field name="model">fnb.order</field>
        <field name="arch" type="xml">
            <tree string="Daftar Pesanan" decoration-info="status == 'draft'" decoration-warning="status == 'kitchen'" decoration-success="status == 'done'">
                <field name="name" string="Nomor Nota"/>
                <field name="order_date" string="Tanggal/Waktu"/>
                <field name="customer_name" string="Pelanggan"/>
                <field name="total_amount" sum="Total Pemasukan"/>
                <field name="payment_status" widget="badge" decoration-success="payment_status == 'paid'" decoration-danger="payment_status == 'unpaid'"/>
                <field name="status" widget="badge" decoration-info="status == 'draft'" decoration-warning="status == 'kitchen'" decoration-success="status == 'done'"/>
            </tree>
        </field>
    </record>

    <record id="view_fnb_order_form" model="ir.ui.view">
        <field name="name">fnb.order.form</field>
        <field name="model">fnb.order</field>
        <field name="arch" type="xml">
            <form string="Nota Pesanan">
                <header>
                    <button name="action_send_to_kitchen" string="Kirim ke Dapur" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                    <button name="action_done" string="Selesaikan Pesanan" type="object" class="oe_highlight" invisible="status != 'kitchen'"/>
                    <button name="action_open_payment_wizard" string="Bayar Tagihan" type="object" class="btn-success" invisible="payment_status == 'paid' or status != 'done'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,kitchen,done"/>
                </header>

                <sheet>
                    <widget name="web_ribbon" title="Lunas" bg_color="bg-success" invisible="payment_status != 'paid'"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_name" placeholder="Nama Pelanggan..."/>
                            <field name="order_date"/>
                            <field name="payment_status" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Daftar Menu" name="order_lines">
                            <field name="order_line_ids">
                                <tree editable="bottom">
                                    <field name="menu_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                    <field name="price_unit"/>
                                    <field name="quantity"/>
                                    <field name="subtotal" sum="Grand Total"/>
                                </tree>
                            </field>

                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_amount" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_fnb_order_kanban" model="ir.ui.view">
        <field name="name">fnb.order.kanban</field>
        <field name="model">fnb.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_mobile" quick_create="false">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="order_date"/>
                <field name="total_amount"/>
                <field name="payment_status"/>
                <field name="status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title" style="font-size: 16px;">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span class="badge rounded-pill text-bg-success" t-if="record.payment_status.raw_value == 'paid'">Lunas</span>
                                <span class="badge rounded-pill text-bg-danger" t-if="record.payment_status.raw_value == 'unpaid'">Belum Bayar</span>
                            </div>
                            
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-user" title="Pelanggan"/> <field name="customer_name"/></div>
                                <div><i class="fa fa-clock-o" title="Waktu"/> <field name="order_date"/></div>
                            </div>
                            
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <strong style="font-size: 15px; color: #017e84;">
                                        Rp <field name="total_amount"/>
                                    </strong>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>